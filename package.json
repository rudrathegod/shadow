{
  "name": "shadow",
  "version": "0.1.5",
  "description": "Open-source macOS invisible AI overlay — three separate inputs (screen, mic, system audio) into an LLM. A Cluely-style copilot for meetings and coding problems.",
  "license": "GPL-3.0-or-later",
  "author": "shadow",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.shadow.overlay",
    "productName": "shadow",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "artifactName": "shadow-mac.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "shadow transcribes your microphone so it can help you in conversations.",
        "NSCameraUsageDescription": "shadow does not use the camera.",
        "NSAudioCaptureUsageDescription": "shadow captures system audio to transcribe the other participant in a call."
      }
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "shadow-win.${ext}"
    }
  },
  "keywords": [
    "electron",
    "overlay",
    "ai",
    "assistant",
    "screencapturekit",
    "macos"
  ],
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^0.3.0",
    "openai": "^4.73.0"
  }
}
